{
  "name": "ppt-kit",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "PPT Kit - AI 驱动的智能演示文稿工具，支持 MCP 协议和 PowerPoint 插件",
  "scripts": {
    "dev": "vite",
    "dev:https": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "certs:install": "node scripts/certs.mjs install",
    "certs:uninstall": "node scripts/certs.mjs uninstall",
    "certs:verify": "node scripts/certs.mjs verify"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.6",
    "mermaid": "^11.4.1",
    "pptxgenjs": "^3.12.0",
    "vue": "^3.5.13",
    "ws": "^8.18.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/file-saver": "^2.0.7",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-vue": "^5.2.3",
    "office-addin-dev-certs": "^1.12.0",
    "office-addin-dev-settings": "^3.0.7",
    "sharp": "^0.34.5",
    "typescript": "~5.7.2",
    "vite": "^6.2.4",
    "vue-tsc": "^2.2.8"
  }
}
